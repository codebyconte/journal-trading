# Neon PostgreSQL — copie ce fichier en .env et remplis tes valeurs
# Dashboard Neon → Connection Details

# Connection POOLÉE (pour l'app Next.js) — avec pgbouncer
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"

# Connection DIRECTE (pour migrations Prisma) — SANS pgbouncer
# Neon → onglet "Direct connection"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# URL publique de l'app (metadata OG, sitemap, canonical, robots)
# Exemple production : https://journal-trading.vercel.app
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
